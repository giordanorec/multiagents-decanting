{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo {\"ts\":\"$(date -u +%FT%TZ)\",\"type\":\"agent_completed\",\"agent\":\"${CLAUDE_SUBAGENT_NAME:-unknown}\"} >> \"${CLAUDE_PROJECT_DIR}/.brainstorm-last-events.jsonl\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
